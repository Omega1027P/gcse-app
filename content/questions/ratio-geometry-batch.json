    "calculatorAllowed": true,
    "questionText": "y is directly proportional to x. When x = 4, y = 10. Find y when x = 6.",
    "finalAnswer": "15",
    "solutionSteps": "y = kx, 10 = 4k, k = 2.5. When x = 6, y = 15",
    "markScheme": [
      { "stepOrder": 1, "markCode": "M1", "description": "Uses y = kx", "points": 1 },
      { "stepOrder": 2, "markCode": "M1", "description": "k = 2.5", "points": 1 },
      { "stepOrder": 3, "markCode": "A1", "description": "15", "points": 1 }
    ],
    "hints": [
      { "level": 1, "text": "Direct proportion means y = kx for some constant k." },
      { "level": 2, "text": "Substitute x = 4, y = 10 to find k." },
      { "level": 3, "text": "k = 2.5, so y = 2.5 × 6 = 15." }
    ],
    "status": "published"
  },
