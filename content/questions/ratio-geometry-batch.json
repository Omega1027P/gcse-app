    "questionText": "In a right-angled triangle, the hypotenuse is 10 cm and one shorter side is 6 cm. Find the other shorter side.",
    "finalAnswer": "8",
    "solutionSteps": "a² = 10² - 6² = 100 - 36 = 64, a = 8 cm",
    "markScheme": [
      { "stepOrder": 1, "markCode": "M1", "description": "Uses Pythagoras", "points": 1 },
      { "stepOrder": 2, "markCode": "M1", "description": "64", "points": 1 },
      { "stepOrder": 3, "markCode": "A1", "description": "8 cm", "points": 1 }
    ],
    "hints": [
      { "level": 1, "text": "Use a² + b² = c² where c is the hypotenuse." },
      { "level": 2, "text": "a² = 10² - 6²." },
      { "level": 3, "text": "a² = 64, a = 8." }
    ],
    "status": "published"
  }
